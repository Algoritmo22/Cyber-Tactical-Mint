# Configuración de 4 terminales en cuadrícula para Pentesting
layout grid

# Terminal 1: Monitoreo
launch sh -c "echo '🛰️  1. MONITOREO DE REDES Y LOGS (wlp4s2)'; exec bash"

# Terminal 2: Ataque
launch sh -c "echo '⚡ 2. CONSOLA DE ATAQUES / METASPLOIT'; exec bash"

# Terminal 3: Scripts
launch sh -c "echo '🔍 3. RECONOCIMIENTO / NMAP'; exec bash"

# Terminal 4: Consola Libre
launch sh -c "echo '🛡️  4. CRACKING Y WEB PENTESTING'; exec bash"
